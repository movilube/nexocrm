# =============================================
# NEXOCRM MOVILUBE - Variables de entorno
# Copiar este archivo como .env y completar
# =============================================

# --- GENERAL ---
PORT=3000
COMPANY_NAME=Movilube
ADMIN_PASSWORD=cambia_esta_contrasena_2026
NODE_ENV=production

# --- ANTHROPIC / CLAUDE IA ---
ANTHROPIC_API_KEY=sk-ant-...

# --- META (WhatsApp + Instagram + Facebook) ---
META_VERIFY_TOKEN=movilube_crm_secreto_2026
WHATSAPP_TOKEN=tu_token_permanente_de_meta
WHATSAPP_PHONE_ID_1=id_del_primer_numero
WHATSAPP_PHONE_ID_2=id_del_segundo_numero
WHATSAPP_PHONE_ID_3=id_del_tercer_numero
INSTAGRAM_TOKEN=tu_page_token_de_facebook
FACEBOOK_PAGE_TOKEN=tu_page_token_de_facebook
FACEBOOK_PAGE_ID=id_de_la_pagina_de_movilube

# --- GOOGLE (Sheets + Calendar) ---
# Pegar el contenido completo del JSON de la cuenta de servicio (en una sola linea)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_SHEETS_ID=id_del_google_sheet_de_precios
GOOGLE_CALENDAR_ID=id_del_calendario_de_turnos
